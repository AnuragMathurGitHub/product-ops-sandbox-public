{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpportunityMap",
  "type": "object",
  "additionalProperties": false,
  "required": ["opportunities", "review_questions"],
  "properties": {
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "opportunity",
          "customer_problem",
          "linked_metric",
          "evidence",
          "possible_solution_direction"
        ],
        "properties": {
          "opportunity": { "type": "string" },
          "customer_problem": { "type": "string" },
          "linked_metric": { "type": "string" },
          "evidence": { "type": "string" },
          "possible_solution_direction": { "type": "string" }
        }
      }
    },
    "review_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
